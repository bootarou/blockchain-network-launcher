# =============================================================================
# Symbol Custom Network Manager - Environment Configuration
# =============================================================================
#
# Docker-in-Docker pattern requires the same path inside the container
# and on the host (WSL2 VM / Linux).
#
# Default: /var/lib/symbol-target
#
# IMPORTANT (Docker Desktop on Windows):
#   /var/lib/ is on the large VHDX (~1TB). Other paths like /opt/ or /tmp/
#   are on the VM's tiny rootFS (~3GB) and will run out of space!
#
# Examples:
#   SYMBOL_TARGET_DIR=/var/lib/symbol-data  (Docker Desktop — recommended)
#   SYMBOL_TARGET_DIR=/data/symbol           (Linux separate partition)
#
SYMBOL_TARGET_DIR=/var/lib/symbol-target
