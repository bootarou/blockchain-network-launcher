# =============================================================================
# Symbol Custom Network Manager — Environment Configuration
# =============================================================================
# このファイルを .env にコピーして値を変更してください:
#   cp .env.example .env
#
# ブロックチェーンデータの保存先パス
# Docker-in-Docker パターンのため、コンテナ内とホスト（WSL2 VM）で
# 同じパスを使用する必要があります。
#
# デフォルト: /opt/symbol-target
# 大容量ディスクを使いたい場合の例:
#   SYMBOL_TARGET_DIR=/mnt/d/symbol-data   (Windows D: ドライブ)
#   SYMBOL_TARGET_DIR=/data/symbol          (Linux 別パーティション)
#
SYMBOL_TARGET_DIR=/opt/symbol-target

# ── セキュリティ ──
# Web UI の管理パスワード。設定するとログイン認証が有効になります。
# 空またはコメントアウトで認証なし（オープンアクセス）。
#ADMIN_PASSWORD=your-strong-password

# Web UI ポート (4000, 5173) のバインドアドレス。
#   127.0.0.1 = ローカルのみ（デフォルト、VPS向け）
#   0.0.0.0   = LAN / リモートからアクセス可（ADMIN_PASSWORD と併用推奨）
#BIND_ADDRESS=0.0.0.0
